# ─── Tikkit Mobile — Environment Variables ───────────────────────────────────
# Copy this file to .env (gitignored) and fill in the values.
# All EXPO_PUBLIC_* vars are inlined at Expo build time (equivalent to NEXT_PUBLIC_*).

# Supabase project URL (found in Supabase Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose in client — RLS enforces access)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Tikkit API base URL (Next.js backend)
EXPO_PUBLIC_API_URL=https://tikkit.xyz
